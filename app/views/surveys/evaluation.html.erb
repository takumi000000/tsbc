  <%= stylesheet_link_tag "https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" %>

  <div class="container">
     <h1 class="text-center header-title">授業に関するアンケート</h1>
      <% q_label = "q" %>
      <% q_label_id = 0 %>
    <%= form_with(url: create_surveys2_path, method: :post, local: true) do |f| %>
    <div class="row mb-4">
      <div class="col-auto">
        <%= f.label :teacher, "担当教師" %>
        <%= f.select :teacher, options_for_select(@teacher), 
          {}, class: "form-select" %>
      </div>
    </div>

      <% q_label = "q" %>
      <% q_label_id = 0 %>
      <% @questions2.each do |que| %>
        <% q_label_id += 1 %>
        <% q_set_label = "q" + q_label_id.to_s %>
        <div class="question-group">
          <div class="question-title">設問<%= q_label_id %>：<%= que.question %></div>
          <div class="form-check form-check-inline">
            <%= f.radio_button q_set_label.to_sym, 5, id: "q1_1", class: "form-check-input" %>
            <%= f.label "q1_1", "そう思う", class: "form-check-label" %>
          </div>
          <div class="form-check form-check-inline">
            <%= f.radio_button q_set_label.to_sym, 4, id: "q1_2", class: "form-check-input" %>
            <%= f.label "q1_2", "ややそう思う", class: "form-check-label" %>
          </div>
          <div class="form-check form-check-inline">
            <%= f.radio_button q_set_label.to_sym, 3, id: "q1_3", class: "form-check-input" %>
            <%= f.label "q1_3", "どちらでもない", class: "form-check-label" %>
          </div>
          <div class="form-check form-check-inline">
            <%= f.radio_button q_set_label.to_sym, 2, id: "q1_4", class: "form-check-input" %>
            <%= f.label "q1_4", "あまりそう思わない", class: "form-check-label" %>
          </div>
          <div class="form-check form-check-inline">
            <%= f.radio_button q_set_label.to_sym, 1, id: "q1_5", class: "form-check-input" %>
            <%= f.label "q1_5", "そう思わない", class: "form-check-label" %>
          </div>
        </div>
      <% end %>

    　<% q_label_id += 1 %>
      <div class="question-group">
        <div class="question-title">質問<%= q_label_id %>：すべて回答しましたか？</div>
        <div class="form-check">
          <%= f.check_box :q11_checked_all, {class: "form-check-input"}, "回答した", nil %>
          <%= f.label :q11_checked_all, "回答した", class: "form-check-label" %>
        </div>
      </div>

      <% q_label_id += 1 %>
      <div class="question-group">
        <div class="question-title">質問<%= q_label_id %>：学校に関してコメントがある人は記入してください。</div>
        <div class="mb-2">
          <label>良いと思う点</label>
          <%= f.text_field :good_points, class: "form-control", placeholder: "例）説明が分かりやすい" %>
        </div>
        <div class="mb-2">
          <label>改善してほしい点</label>
          <%= f.text_field :improvement_points, class: "form-control", placeholder: "例）こんな所を直してほしい" %>
        </div>
      </div>

      <div class="text-end mt-4">
        <%= f.submit "次へ", class: "btn btn-primary" %>
      </div>
    <% end %>

    <%= link_to "終了する", fin_path %>
  </div>

  <%= javascript_include_tag "https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" %>
</body>
</html>
